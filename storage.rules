// ============================================================
// REGRAS DE SEGURANÇA — Firebase Storage
// GPC Sistema Analítico · R2 Soluções
// Versão 2.0 (usado pela página de Processamento)
// ============================================================
// Copie e cole em: Firebase Console → Storage → Regras

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
             firestore.exists(/databases/(default)/documents/usuarios/$(request.auth.uid)) &&
             firestore.get(/databases/(default)/documents/usuarios/$(request.auth.uid)).data.perfil == 'admin';
    }

    function isAdminOrGestor() {
      return isSignedIn() &&
             firestore.exists(/databases/(default)/documents/usuarios/$(request.auth.uid)) &&
             (firestore.get(/databases/(default)/documents/usuarios/$(request.auth.uid)).data.perfil == 'admin' ||
              firestore.get(/databases/(default)/documents/usuarios/$(request.auth.uid)).data.perfil == 'gestor');
    }

    // ------------------------------------------------------------
    // uploads/{base}/{rotina}/{arquivo}
    // ------------------------------------------------------------
    // XLSX enviados pela página de Processamento
    // - Leitura: admin e gestor (baixar histórico)
    // - Escrita: admin e gestor, tipo XLSX/XLS, limite 25 MB
    match /uploads/{base}/{rotina}/{filename} {
      allow read: if isAdminOrGestor();
      allow write: if isAdminOrGestor() &&
                      request.resource.size < 25 * 1024 * 1024 &&
                      (request.resource.contentType.matches('application/vnd.openxmlformats.*') ||
                       request.resource.contentType.matches('application/vnd.ms-excel') ||
                       request.resource.contentType == 'application/octet-stream');
      allow delete: if false;
    }

    // ------------------------------------------------------------
    // Catch-all: bloqueia qualquer outro caminho
    // ------------------------------------------------------------
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
